NODE_ENV=development
CHATAVG_PORT=8200
CHATAVG_SECRET=replace-this-with-at-least-32-random-characters-for-jwt
CHATAVG_TOKEN_EXPIRY=7d
CHATAVG_ADMIN_PASSWORD=change-me-immediately
CHATAVG_ALLOWED_ORIGINS=http://127.0.0.1:8200,http://localhost:8200
CHATAVG_PROVIDER_TIMEOUT=60000
CHATAVG_TEST_TIMEOUT=5000
ALLOW_CUSTOM_PROVIDER_URLS=false
