{
  "name": "chatavg-platform",
  "version": "2.3.0",
  "description": "ChatAVG: Semantic Agent Platform",
  "private": true,
  "scripts": {
    "setup": "npm install --prefix cons/chatavg && npm install --prefix cons/mcp_gateway",
    "start": "npm run start --prefix cons/chatavg",
    "gateway": "npm run start --prefix cons/mcp_gateway",
    "worker": "npm run worker --prefix cons/chatavg",
    "test": "npm run test:release --prefix cons/chatavg",
    "test:unit": "npm run test:unit --prefix cons/chatavg",
    "test:contract": "npm run test:contract --prefix cons/chatavg",
    "test:security": "npm run test:security --prefix cons/chatavg",
    "test:policy": "npm run test:policy --prefix cons/chatavg",
    "test:knowledge": "npm run test:knowledge --prefix cons/chatavg",
    "test:execution": "npm run test:execution --prefix cons/chatavg",
    "test:tools": "npm run test:tools --prefix cons/chatavg",
    "test:remediation": "npm run test:remediation --prefix cons/chatavg",
    "test:sandbox": "npm run test:sandbox --prefix cons/chatavg",
    "test:semantic": "npm run test:semantic --prefix cons/chatavg",
    "test:all": "npm run test:release && npm run test:remediation",
    "docs:validate": "bash scripts/validate_docs.sh",
    "docs:dashboard": "python3 scripts/generate_quality_dashboard.py docs/ > docs/QUALITY_REPORT.md",
    "docs:check-metadata": "python3 scripts/check_doc_metadata.py docs/",
    "docs:lint": "markdownlint '**/*.md' --config .markdownlint.jsonc --ignore node_modules --ignore .git"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
